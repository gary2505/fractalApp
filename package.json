    "gate:mf": "node scripts/gate-mf.mjs",
    "gate:policy": "node scripts/gate-policy.mjs",
    "gate:bind": "node scripts/gate-bind.mjs",
    "gate:patch": "node scripts/gate-patch.mjs",
