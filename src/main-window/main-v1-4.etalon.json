{
  "id": "main-v1-4.etalon",
  "versionId": "main-v1-4",
  "expectedLayout": {
    "rows": ["top-row", "top-bar", "main-row", "status-bar"],
    "mainRowPanels": ["p0", "p1", "p2", "p3", "p4"],
    "nestedPanels": {
      "p3": ["p3h1", "p3h2"],
      "p4": ["P4V1", "P4V2"]
    },
    "childFiles": {
      "top-row": "top-row-v1-0.svelte",
      "top-bar": "top-bar-v1-0.svelte",
      "p0": "p0-v1-0.svelte",
      "p1": "p1-v1-0.svelte",
      "p2": "p2-v1-0.svelte",
      "p3": "p3-v1-0.svelte",
      "p3h1": "p3h1-v1-0.svelte",
      "p3h2": "p3h2-v1-0.svelte",
      "p4": "p4-v1-0.svelte",
      "status-bar": "status-bar-v1-0.svelte"
    },
    "topTabs": [
      { "label": "Tab 1", "role": "AI Editor" },
      { "label": "Tab 2", "role": "File Explorer" },
      { "label": "Tab 3", "role": "Analysis" },
      { "label": "Tab 4", "role": "Review" }
    ],
    "defaultState": {
      "activeTopTab": "ai-editor",
      "agentSide": "right",
      "p0Visible": true,
      "p1Visible": false,
      "p2Visible": true,
      "p3h2Visible": true,
      "p4Visible": true,
      "p4v2Visible": false,
      "sbarVisible": true
    },
    "hotkeys": {
      "Ctrl+E": "switch agent side",
      "Ctrl+B": "toggle P2 files panel",
      "Ctrl+J": "toggle P3H2 terminal panel",
      "Ctrl+Alt+B": "toggle P4 AI chat panel",
      "Esc": "close P4V2 sidebar when open"
    }
  }
}
